@model SIGEBI.Web.Controllers.ListaDeseosViewModel
@{
    ViewData["Title"] = "Lista de Deseos";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SIGEBI - Lista de Deseos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --green-900: #0f3d20; --green-800: #1a5c2e; --green-600: #2e8b4a;
            --green-400: #4caf7d; --green-100: #e8f5ee; --cream: #faf8f4;
            --ink: #1a1f1c; --muted: #5a6b60; --border: #dde8e2;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background-color: var(--cream); font-family: 'Outfit', sans-serif; color: var(--ink); min-height: 100vh; }

        .navbar { background-color: #0d2e18; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 20px rgba(0,0,0,0.18); }
        .navbar-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .brand-text { font-size: 1.7rem; font-weight: 700; color: white; letter-spacing: 1px; }
        .brand-sub { font-size: 0.65rem; color: rgba(255,255,255,0.5); letter-spacing: 2px; text-transform: uppercase; display: block; }
        .nav-links { display: flex; align-items: center; gap: 4px; }
        .nav-link { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.82rem; font-weight: 500; padding: 7px 14px; border-radius: 6px; transition: all 0.2s; display: flex; align-items: center; gap: 6px; }
        .nav-link:hover, .nav-link.active { color: white; background: rgba(255,255,255,0.1); }
        .nav-divider { width: 1px; height: 20px; background: rgba(255,255,255,0.15); margin: 0 6px; }

        .notification-dot {
            position: absolute;
            top: -2px;
            right: -2px;
            width: 8px;
            height: 8px;
            background-color: #ff4d4f;
            border-radius: 50%;
            border: 1.5px solid #0d2e18;
            display: none;
            box-shadow: 0 0 0 2px rgba(255,77,79,0.2);
        }

        .page-header { background: linear-gradient(160deg, rgba(15,61,32,0.92) 0%, rgba(26,92,46,0.88) 60%, rgba(46,139,74,0.85) 100%); padding: 3rem 2.5rem 4rem; }
        .header-content { max-width: 1100px; margin: 0 auto; }
        .header-eyebrow { font-size: 0.72rem; letter-spacing: 3px; text-transform: uppercase; color: var(--green-400); font-weight: 600; margin-bottom: 10px; }
        .header-title { font-size: 2.2rem; font-weight: 700; color: white; margin-bottom: 6px; }
        .header-subtitle { color: rgba(255,255,255,0.6); font-size: 0.95rem; font-weight: 300; }

        .main-content { max-width: 1100px; margin: 0 auto; padding: 2.5rem 2.5rem 4rem; }

        .deseos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.4rem; }
        .deseo-card { background: white; border-radius: 14px; border: 1px solid var(--border); overflow: hidden; transition: transform 0.25s, box-shadow 0.25s; animation: fadeUp 0.35s ease both; }
        .deseo-card:hover { transform: translateY(-4px); box-shadow: 0 10px 28px rgba(15,61,32,0.1); }
        .card-cover { 
            height: 140px; 
            background: linear-gradient(135deg, #0f3d20, #2e8b4a); 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            overflow: hidden;
        }
        .card-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.9;
            transition: opacity 0.3s;
        }
        .card-cover:hover img { opacity: 1; }
        .card-cover .bi-book { font-size: 2.6rem; color: rgba(255,255,255,0.2); }
        .card-body { padding: 1rem 1.1rem 0.8rem; }
        .card-title { font-size: 0.98rem; font-weight: 600; color: var(--ink); margin-bottom: 4px; line-height: 1.35; }
        .card-autor { font-size: 0.8rem; color: var(--muted); margin-bottom: 2px; }
        .card-categoria { font-size: 0.75rem; color: var(--green-600); font-weight: 600; }
        .card-footer { padding: 0.8rem 1.1rem; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; }
        .btn-quitar { font-size: 0.8rem; color: #c62828; font-weight: 600; background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 4px; padding: 0; }
        .btn-quitar:hover { color: #8b0000; }

        .empty-state { text-align: center; padding: 80px 20px; color: var(--muted); }
        .empty-icon { width: 72px; height: 72px; background: var(--green-100); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.2rem; font-size: 1.8rem; color: var(--green-600); }
        .empty-state h4 { font-size: 1.3rem; color: var(--ink); margin-bottom: 6px; font-weight: 600; }
        .btn-explorar { display: inline-flex; align-items: center; gap: 8px; margin-top: 1rem; background: var(--green-600); color: white; padding: 10px 22px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: background 0.2s; }
        .btn-explorar:hover { background: var(--green-800); color: white; }

        @@keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <nav class="navbar">
        <a class="navbar-brand" href="/Catalogo/Index">
            <div>
                <span class="brand-text">SIGEBI</span>
                <span class="brand-sub">Biblioteca</span>
            </div>
        </a>
        <div class="nav-links">
            <a class="nav-link" href="/Catalogo/Index"><i class="bi bi-grid"></i> Catálogo</a>
            <a class="nav-link active" href="/ListaDeseos/Index"><i class="bi bi-heart"></i> Lista de Deseos</a>
            <a class="nav-link" href="/Prestamos/Index"><i class="bi bi-book"></i> Mis Préstamos</a>
            <a class="nav-link" href="/Notificaciones/Index">
                <span style="position: relative; display: inline-flex;">
                    <i class="bi bi-bell"></i>
                    <span id="unread-dot" class="notification-dot"></span>
                </span>
                Notificaciones
            </a>
            <div class="nav-divider"></div>
            <a class="nav-link" href="/Perfil/Index"><i class="bi bi-person-circle"></i> Perfil</a>
        </div>
    </nav>

    <div class="page-header">
        <div class="header-content">
            <p class="header-eyebrow">Mi colección</p>
            <h1 class="header-title">Lista de Deseos</h1>
            <p class="header-subtitle">Los recursos que guardaste para pedir prestado después</p>
        </div>
    </div>

    <div class="main-content">
        @if (!Model.Items.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="bi bi-heart"></i></div>
                <h4>Tu lista de deseos está vacía</h4>
                <p>Explorá el catálogo y guardá los recursos que te interesen.</p>
                <a href="/Catalogo/Index" class="btn-explorar"><i class="bi bi-grid"></i> Explorar catálogo</a>
            </div>
        }
        else
        {
            <div class="deseos-grid">
                @foreach (var item in Model.Items)
                {
                    <div class="deseo-card">
                        <div class="card-cover">
                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="@(Model.ApiBaseUrl.TrimEnd('/') + "/" + item.ImagenUrl.TrimStart('/'))" alt="@item.RecursoTitulo" />
                            }
                            else
                            {
                                <i class="bi bi-book"></i>
                            }
                        </div>
                        <div class="card-body">
                            <h3 class="card-title">@item.RecursoTitulo</h3>
                            <p class="card-autor"><i class="bi bi-person"></i> @item.RecursoAutor</p>
                            <p class="card-categoria"><i class="bi bi-tag"></i> @(string.IsNullOrEmpty(item.CategoriaNombre) ? "Sin categoría" : item.CategoriaNombre)</p>
                        </div>
                        <div class="card-footer">
                            <button class="btn-quitar" onclick="quitarDeseo('@item.Id')">
                                <i class="bi bi-trash"></i> Quitar
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function quitarDeseo(id) {
            if (!confirm('¿Seguro que quieres quitar este recurso de tu lista?')) return;
            
            $.post('/ListaDeseos/Quitar', { id: id }, function(data) {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }

        // Script para el punto rojo de notificaciones
        (function() {
            fetch('/Notificaciones/GetUnreadCount')
                .then(response => response.json())
                .then(data => {
                    const dot = document.getElementById('unread-dot');
                    if (data.count > 0 && dot) {
                        dot.style.display = 'block';
                    }
                })
                .catch(err => console.error('Error fetching unread count:', err));
        })();
    </script>

</body>
</html>

