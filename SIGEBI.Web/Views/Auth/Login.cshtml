@model SIGEBI.Web.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesion";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SIGEBI - Iniciar Sesion</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        html, body {
            height: 100%;
            width: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            background-color: #0d2e18; /* Dark green fallback */
        }

        /* Library photo background */
        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('/img/login_bg_v3.png');
            background-size: cover;
            background-position: center;
            filter: brightness(0.9) contrast(1.1);
            z-index: 0;
        }

        /* Dark green transparent overlay */
        body::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(
                135deg,
                rgba(15, 61, 32, 0.65) 0%,
                rgba(10, 45, 20, 0.55) 100%
            );
            z-index: 1;
        }

        .login-card {
            position: relative;
            z-index: 2;
            width: 480px;
            border-radius: 6px;
            box-shadow: 0 12px 48px rgba(0,0,0,0.5);
            border: 0 !important;
            overflow: hidden;
            background-color: #0f3d20; /* Matches header to prevent white bleeding at corners */
        }

        .login-header {
            background-color: #0f3d20;
            color: white;
            padding: 44px 36px;
            text-align: center;
            border-top-left-radius: 6px;
            border-top-right-radius: 6px;
        }

            .login-header .logo-icon {
                font-size: 3rem;
                margin-bottom: 8px;
                display: block;
            }

            .login-header h3 {
                font-size: 2.25rem;
                font-weight: 700;
                margin-bottom: 6px;
                letter-spacing: 3px;
            }

            .login-header p {
                font-size: 0.85rem;
                opacity: 0.85;
                margin: 0;
            }

        .card-body {
            padding: 44px 40px;
            background-color: #ffffff;
            border-bottom-left-radius: 6px;
            border-bottom-right-radius: 6px;
        }

        .form-control {
            border-radius: 4px;
            border: 1.5px solid #c8e6c9;
            padding: 10px 14px;
        }

            .form-control:focus {
                border-color: #2e8b4a;
                box-shadow: 0 0 0 0.2rem rgba(46,139,74,0.15);
            }

        .btn-login {
            background-color: #2e8b4a;
            border: none;
            color: white;
            font-weight: 600;
            padding: 14px;
            border-radius: 4px;
            font-size: 1.1rem;
            transition: background-color 0.2s;
        }

            .btn-login:hover {
                background-color: #0f3d20;
                color: white;
            }

        .form-label {
            font-weight: 500;
            color: #1a5c2e;
            margin-bottom: 6px;
        }

        .footer-card {
            background-color: #f4f9f6;
            text-align: center;
            padding: 12px;
            font-size: 0.78rem;
            color: #6c8c76;
        }
    </style>
</head>

<body>

    <div class="card login-card">

        <div class="login-header">
            <h3>SIGEBI</h3>
            <p>Sistema de Gestion Bibliotecaria</p>
        </div>

        <div class="card-body">

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2">
                    @Model.ErrorMessage
                </div>
            }

            @if (TempData["LogoutMessage"] != null)
            {
                <div class="alert alert-warning py-2">
                    @TempData["LogoutMessage"]
                </div>
            }

            <form method="post">

                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">
                        Correo electronico
                    </label>

                    <input asp-for="Correo"
                           type="email"
                           class="form-control"
                           required
                           maxlength="100"
                           placeholder="correo@ejemplo.com" />

                </div>

                <div class="mb-4">
                    <label class="form-label">
                        Contrasena
                    </label>

                    <input asp-for="Contrasena"
                           type="password"
                           class="form-control"
                           required
                           maxlength="50"
                           placeholder="••••••••" />

                </div>

                <button type="submit" class="btn btn-login w-100">
                    Iniciar Sesion
                </button>

            </form>

            
            <p style="text-align:center; margin-top:1.2rem; font-size:0.75rem; color:#8a9e90;">
                ¿Problemas para acceder? Contacta al bibliotecario.
            </p>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
