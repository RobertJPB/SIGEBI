@model SIGEBI.Web.Controllers.PerfilIndexViewModel
@{
    ViewData["Title"] = "Mi Perfil";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SIGEBI - Mi Perfil</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --green-900: #0f3d20; --green-800: #1a5c2e; --green-600: #2e8b4a;
            --green-400: #4caf7d; --green-100: #e8f5ee; --cream: #faf8f4;
            --ink: #1a1f1c; --muted: #5a6b60; --border: #dde8e2;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background-color: var(--cream); font-family: 'Outfit', sans-serif; color: var(--ink); min-height: 100vh; }

        .navbar { background-color: #0d2e18; padding: 0 2.5rem; height: 64px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 20px rgba(0,0,0,0.18); }
        .navbar-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .brand-text { font-size: 1.7rem; font-weight: 700; color: white; letter-spacing: 1px; }
        .brand-sub { font-size: 0.65rem; color: rgba(255,255,255,0.5); letter-spacing: 2px; text-transform: uppercase; display: block; }
        .nav-links { display: flex; align-items: center; gap: 4px; }
        .nav-link { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.82rem; font-weight: 500; padding: 7px 14px; border-radius: 6px; transition: all 0.2s; display: flex; align-items: center; gap: 6px; }
        .nav-link:hover, .nav-link.active { color: white; background: rgba(255,255,255,0.1); }
        .nav-divider { width: 1px; height: 20px; background: rgba(255,255,255,0.15); margin: 0 6px; }

        .page-header { background: linear-gradient(160deg, rgba(15,61,32,0.92) 0%, rgba(26,92,46,0.88) 60%, rgba(46,139,74,0.85) 100%); padding: 3rem 2.5rem 4rem; }
        .header-content { max-width: 800px; margin: 0 auto; }
        .header-eyebrow { font-size: 0.72rem; letter-spacing: 3px; text-transform: uppercase; color: var(--green-400); font-weight: 600; margin-bottom: 10px; }
        .header-title { font-size: 2.2rem; font-weight: 700; color: white; margin-bottom: 6px; }

        .main-content { max-width: 800px; margin: 0 auto; padding: 2.5rem 2.5rem 4rem; }

        .perfil-card {
            background: white;
            border-radius: 16px;
            border: 1px solid var(--border);
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(15,61,32,0.07);
        }
        .perfil-header {
            background: var(--green-800);
            padding: 2.5rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }
        .avatar {
            width: 80px; height: 80px;
            border-radius: 50%;
            background: var(--green-400);
            display: flex; align-items: center; justify-content: center;
            font-size: 2rem; color: white; font-weight: 700;
            flex-shrink: 0;
        }
        .perfil-info h2 { font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 4px; }
        .perfil-info p { font-size: 0.85rem; color: rgba(255,255,255,0.65); }
        .rol-badge { display: inline-block; background: var(--green-400); color: white; font-size: 0.72rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 3px 10px; border-radius: 20px; margin-top: 6px; }

        .perfil-body { padding: 2rem; }
        .campo-grupo { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin-bottom: 1.2rem; }
        .campo { }
        .campo label { display: block; font-size: 0.75rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 6px; }
        .campo p { font-size: 0.95rem; color: var(--ink); font-weight: 500; background: var(--green-50, #f4faf7); padding: 10px 14px; border-radius: 8px; border: 1px solid var(--border); }
        .campo-full { margin-bottom: 1.2rem; }

        .btn-logout {
            display: inline-flex; align-items: center; gap: 8px;
            background: #fdecea; color: #c62828; padding: 10px 22px;
            border-radius: 8px; font-weight: 600; font-size: 0.9rem;
            text-decoration: none; transition: background 0.2s; border: none; cursor: pointer;
        }
        .btn-logout:hover { background: #f5c6cb; }
        .perfil-footer { padding: 1.2rem 2rem; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; }
    </style>
</head>
<body>

    <nav class="navbar">
        <a class="navbar-brand" href="/Catalogo/Index">
            <div>
                <span class="brand-text">SIGEBI</span>
                <span class="brand-sub">Biblioteca</span>
            </div>
        </a>
        <div class="nav-links">
            <a class="nav-link" href="/Catalogo/Index"><i class="bi bi-grid"></i> CatÃ¡logo</a>
            <a class="nav-link" href="/ListaDeseos/Index"><i class="bi bi-heart"></i> Lista de Deseos</a>
            <a class="nav-link" href="/Prestamos/Index"><i class="bi bi-book"></i> Mis PrÃ©stamos</a>
            <a class="nav-link" href="/Notificaciones/Index"><i class="bi bi-bell"></i> Notificaciones</a>
            <div class="nav-divider"></div>
            <a class="nav-link active" href="/Perfil/Index"><i class="bi bi-person-circle"></i> Perfil</a>
        </div>
    </nav>

    <div class="page-header">
        <div class="header-content">
            <p class="header-eyebrow">ConfiguraciÃ³n</p>
            <h1 class="header-title">Mi Perfil</h1>
        </div>
    </div>

    <div class="main-content">
        <div class="perfil-card">
            <div class="perfil-header">
                <div class="avatar">@(Model.Nombre?.Length > 0 ? Model.Nombre[0].ToString().ToUpper() : "?")</div>
                <div class="perfil-info">
                    <h2>@Model.Nombre</h2>
                    <p>@Model.Correo</p>
                    <span class="rol-badge">@Model.Rol</span>
                </div>
            </div>
            <div class="perfil-body">
                <div class="campo-grupo">
                    <div class="campo">
                        <label>Nombre completo</label>
                        <p>@Model.Nombre</p>
                    </div>
                    <div class="campo">
                        <label>Correo electrÃ³nico</label>
                        <p>@Model.Correo</p>
                    </div>
                </div>
                <div class="campo-grupo">
                    <div class="campo">
                        <label>Rol</label>
                        <p>@Model.Rol</p>
                    </div>
                    <div class="campo">
                        <label>Estado de cuenta</label>
                        <p>@Model.Estado</p>
                    </div>
                </div>
            </div>
            <div class="perfil-footer">
                <form method="post" asp-page-handler="Logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-left"></i> Cerrar sesiÃ³n
                    </button>
                </form>
            </div>
        </div>
    </div>

</body>
</html>

