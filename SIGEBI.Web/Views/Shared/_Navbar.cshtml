@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@using Microsoft.AspNetCore.Http
@{
    var activePage = ViewData["ActivePage"]?.ToString() ?? "";
    var apiBase = (ViewBag.ApiBaseUrl as string) ?? Configuration["ApiSettings:BaseUrl"] ?? "https://localhost:7047";
    apiBase = apiBase.TrimEnd('/');
    
    // COMENTARIO PARA EXPLICACIÓN:
    // Sincronización en Tiempo Real:
    // Los Claims (Context.User) son inmutables durante la sesión. Para que la UI se actualice
    // inmediatamente cuando el usuario cambia su foto o nombre, priorizamos los valores 
    // almacenados en la Sesión (Context.Session), los cuales podemos mutar en el PerfilController.
    var userImg = Context.Session.GetString("UsuarioImagen") ?? Context.User.FindFirst("UsuarioImagen")?.Value;
    var userName = Context.Session.GetString("UsuarioNombre") ?? Context.User.Identity?.Name ?? "Perfil";
}

<nav class="navbar">
    <a class="navbar-brand" href="/Catalogo/Index">
        <div>
            <span class="brand-text">SIGEBI</span>
            <span class="brand-sub">Biblioteca</span>
        </div>
    </a>
    <div class="nav-links">
        <a class="nav-link @(activePage == "Catalogo" ? "active" : "")" href="/Catalogo/Index"><i class="bi bi-grid"></i> Catálogo</a>
        <a class="nav-link @(activePage == "ListaDeseos" ? "active" : "")" href="/ListaDeseos/Index"><i class="bi bi-heart"></i> Lista de Deseos</a>
        <a class="nav-link @(activePage == "Prestamos" ? "active" : "")" href="/Prestamos/Index"><i class="bi bi-book"></i> Mis Préstamos</a>
        <a class="nav-link @(activePage == "Notificaciones" ? "active" : "")" href="/Notificaciones/Index">
            <span style="position: relative; display: inline-flex;">
                <i class="bi bi-bell"></i>
                <span id="unread-dot" class="notification-dot"></span>
            </span>
            Notificaciones
        </a>
        <div class="nav-divider"></div>
        <a class="nav-link @(activePage == "Perfil" ? "active" : "")" href="/Perfil/Index">
            @if (!string.IsNullOrEmpty(userImg))
            {
                var fullImgUrl = apiBase + "/" + userImg.TrimStart('/');
                <img src="@fullImgUrl" style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(255,255,255,0.3);" />
            }
            else
            {
                <i class="bi bi-person-circle"></i>
            }
            @userName
        </a>
    </div>
</nav>

<script>
    // Script para el punto rojo de notificaciones
    (function() {
        if (document.getElementById('unread-dot')) {
            fetch('/Notificaciones/GetUnreadCount')
                .then(response => response.json())
                .then(data => {
                    const dot = document.getElementById('unread-dot');
                    if (data.count > 0 && dot) {
                        dot.style.display = 'block';
                    }
                })
                .catch(err => console.error('Error fetching unread count:', err));
        }
    })();
</script>
