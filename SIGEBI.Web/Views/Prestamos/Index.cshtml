@model SIGEBI.Web.Controllers.PrestamosIndexViewModel
@{
    ViewData["Title"] = "Mis Préstamos";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SIGEBI - Mis Préstamos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --green-900: #0f3d20;
            --green-800: #1a5c2e;
            --green-600: #2e8b4a;
            --green-400: #4caf7d;
            --green-100: #e8f5ee;
            --cream: #faf8f4;
            --ink: #1a1f1c;
            --muted: #5a6b60;
            --border: #dde8e2;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background-color: var(--cream); font-family: 'Outfit', sans-serif; color: var(--ink); min-height: 100vh; }

        .navbar {
            background-color: #0d2e18;
            padding: 0 2.5rem;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 20px rgba(0,0,0,0.18);
        }
        .navbar-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .brand-text { font-size: 1.7rem; font-weight: 700; color: white; letter-spacing: 1px; }
        .brand-sub { font-size: 0.65rem; color: rgba(255,255,255,0.5); letter-spacing: 2px; text-transform: uppercase; display: block; line-height: 1; margin-top: 1px; }
        .nav-links { display: flex; align-items: center; gap: 4px; }
        .nav-link { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.82rem; font-weight: 500; padding: 7px 14px; border-radius: 6px; transition: all 0.2s; display: flex; align-items: center; gap: 6px; }
        .nav-link:hover, .nav-link.active { color: white; background: rgba(255,255,255,0.1); }
        .nav-divider { width: 1px; height: 20px; background: rgba(255,255,255,0.15); margin: 0 6px; }

        .notification-dot {
            position: absolute;
            top: -2px;
            right: -2px;
            width: 8px;
            height: 8px;
            background-color: #ff4d4f;
            border-radius: 50%;
            border: 1.5px solid #0d2e18;
            display: none;
            box-shadow: 0 0 0 2px rgba(255,77,79,0.2);
        }

        .page-header {
            background: linear-gradient(160deg, rgba(15,61,32,0.92) 0%, rgba(26,92,46,0.88) 60%, rgba(46,139,74,0.85) 100%);
            padding: 3rem 2.5rem 4rem;
        }
        .header-content { max-width: 1100px; margin: 0 auto; }
        .header-eyebrow { font-size: 0.72rem; letter-spacing: 3px; text-transform: uppercase; color: var(--green-400); font-weight: 600; margin-bottom: 10px; }
        .header-title { font-size: 2.2rem; font-weight: 700; color: white; margin-bottom: 6px; }
        .header-subtitle { color: rgba(255,255,255,0.6); font-size: 0.95rem; font-weight: 300; }

        .main-content { max-width: 1100px; margin: 0 auto; padding: 2.5rem 2.5rem 4rem; }

        .prestamos-table-wrap {
            background: white;
            border-radius: 6px;
            border: 1px solid var(--border);
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(15,61,32,0.06);
        }
        table { width: 100%; border-collapse: collapse; }
        thead { background: var(--green-800); color: white; }
        thead th { padding: 14px 18px; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; }
        tbody tr { border-bottom: 1px solid var(--border); transition: background 0.15s; }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: var(--green-100); }
        tbody td { padding: 14px 18px; font-size: 0.9rem; color: var(--ink); vertical-align: middle; }

        .badge-activo { background: var(--green-100); color: var(--green-800); padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
        .badge-devuelto { background: #e8eaf6; color: #3949ab; padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
        .badge-atrasado { background: #fdecea; color: #c62828; padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }

        .empty-state { text-align: center; padding: 80px 20px; color: var(--muted); }
        .empty-icon { width: 72px; height: 72px; background: var(--green-100); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.2rem; font-size: 1.8rem; color: var(--green-600); }
        .empty-state h4 { font-size: 1.3rem; color: var(--ink); margin-bottom: 6px; font-weight: 600; }

        .alert-error { background: #fdecea; border: 1px solid #f5c6cb; color: #c62828; padding: 12px 18px; border-radius: 10px; margin-bottom: 1.5rem; font-size: 0.9rem; }

        /* Alineación de columnas */
        table th:nth-child(n+2), 
        table td:nth-child(n+2) {
            text-align: center;
        }
        
        .badge-activo, .badge-devuelto, .badge-atrasado {
            display: inline-block;
            min-width: 90px;
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a class="navbar-brand" href="/Catalogo/Index">
            <div>
                <span class="brand-text">SIGEBI</span>
                <span class="brand-sub">Biblioteca</span>
            </div>
        </a>
        <div class="nav-links">
            <a class="nav-link" href="/Catalogo/Index"><i class="bi bi-grid"></i> Catálogo</a>
            <a class="nav-link" href="/ListaDeseos/Index"><i class="bi bi-heart"></i> Lista de Deseos</a>
            <a class="nav-link active" href="/Prestamos/Index"><i class="bi bi-book"></i> Mis Préstamos</a>
            <a class="nav-link" href="/Notificaciones/Index">
                <span style="position: relative; display: inline-flex;">
                    <i class="bi bi-bell"></i>
                    <span id="unread-dot" class="notification-dot"></span>
                </span>
                Notificaciones
            </a>
            <div class="nav-divider"></div>
            <a class="nav-link" href="/Perfil/Index"><i class="bi bi-person-circle"></i> Perfil</a>
        </div>
    </nav>

    <div class="page-header">
        <div class="header-content">
            <p class="header-eyebrow">Mi cuenta</p>
            <h1 class="header-title">Mis Préstamos</h1>
            <p class="header-subtitle">Historial de libros prestados y sus estados</p>
        </div>
    </div>

    <div class="main-content">

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert-error"><i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage</div>
        }

        @if (!Model.Prestamos.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="bi bi-book"></i></div>
                <h4>No tienes préstamos registrados</h4>
                <p>Explora el catálogo y solicita tu primer préstamo.</p>
            </div>
        }
        else
        {
            <div class="prestamos-table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Recurso</th>
                            <th>Fecha inicio</th>
                            <th>Fecha límite</th>
                            <th>Fecha devolución</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Prestamos)
                        {
                            <tr>
                                <td><strong>@p.TituloRecurso</strong></td>
                                <td>@p.FechaInicio</td>
                                <td>@p.FechaDevolucionEstimada</td>
                                <td>
                                    @if (string.IsNullOrEmpty(p.FechaDevolucionReal))
                                    {
                                        <span style="color: var(--muted); font-style: italic;">En Uso</span>
                                    }
                                    else
                                    {
                                        @p.FechaDevolucionReal
                                    }
                                </td>
                                <td>
                                    @{
                                        var estadoLower = p.Estado.ToLower();
                                        var badgeClass = estadoLower switch {
                                            "activo"    => "badge-activo",
                                            "devuelto"  => "badge-devuelto",
                                            "atrasado"  => "badge-atrasado",
                                            _           => "badge-activo"
                                        };
                                        var estadoTexto = estadoLower switch {
                                            "activo"    => "Pendiente",
                                            "devuelto"  => "Devuelto",
                                            "atrasado"  => "Atrasado",
                                            _           => p.Estado
                                        };
                                    }
                                    <span class="@badgeClass">@estadoTexto</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    </div>

    <script>
        // Script para el punto rojo de notificaciones
        (function() {
            fetch('/Notificaciones/GetUnreadCount')
                .then(response => response.json())
                .then(data => {
                    const dot = document.getElementById('unread-dot');
                    if (data.count > 0 && dot) {
                        dot.style.display = 'block';
                    }
                })
                .catch(err => console.error('Error fetching unread count:', err));
        })();
    </script>
</body>
</html>
