@page
@model SIGEBI.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Iniciar Sesion";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SIGEBI - Iniciar Sesion</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #1a5c2e 0%, #2e8b4a 50%, #4caf7d 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .login-card {
            width: 420px;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.25);
            border: none;
            overflow: hidden;
        }

        .login-header {
            background-color: #1a5c2e;
            color: white;
            padding: 36px 28px;
            text-align: center;
        }

            .login-header .logo-icon {
                font-size: 3rem;
                margin-bottom: 8px;
                display: block;
            }

            .login-header h3 {
                font-size: 2rem;
                font-weight: 700;
                margin-bottom: 4px;
                letter-spacing: 2px;
            }

            .login-header p {
                font-size: 0.85rem;
                opacity: 0.85;
                margin: 0;
            }

        .card-body {
            padding: 36px 32px;
            background-color: #ffffff;
        }

        .form-control {
            border-radius: 8px;
            border: 1.5px solid #c8e6c9;
            padding: 10px 14px;
        }

            .form-control:focus {
                border-color: #2e8b4a;
                box-shadow: 0 0 0 0.2rem rgba(46,139,74,0.15);
            }

        .btn-login {
            background-color: #2e8b4a;
            border: none;
            color: white;
            font-weight: 600;
            padding: 12px;
            border-radius: 8px;
            font-size: 1rem;
            transition: background-color 0.2s;
        }

            .btn-login:hover {
                background-color: #1a5c2e;
                color: white;
            }

        .form-label {
            font-weight: 500;
            color: #1a5c2e;
            margin-bottom: 6px;
        }

        .footer-card {
            background-color: #f4f9f6;
            text-align: center;
            padding: 12px;
            font-size: 0.78rem;
            color: #6c8c76;
        }
    </style>
</head>

<body>

    <div class="card login-card">

        <div class="login-header">
            <span class="logo-icon"></span>
            <h3>SIGEBI</h3>
            <p>Sistema de Gestion Bibliotecaria</p>
        </div>

        <div class="card-body">

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">

                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">
                        <i class="bi bi-envelope me-1"></i>Correo electronico
                    </label>

                    <input asp-for="Correo"
                           type="email"
                           class="form-control"
                           placeholder="correo@ejemplo.com" />

                </div>

                <div class="mb-4">
                    <label class="form-label">
                        <i class="bi bi-lock me-1"></i>Contrasena
                    </label>

                    <input asp-for="Contrasena"
                           type="password"
                           class="form-control"
                           placeholder="••••••••" />

                </div>

                <button type="submit" class="btn btn-login w-100">
                    <i class="bi bi-box-arrow-in-right me-2"></i>
                    Iniciar Sesion
                </button>

            </form>

            
            <p style="text-align:center; margin-top:1.2rem; font-size:0.75rem; color:#8a9e90;">
                ¿Problemas para acceder? Contacta al bibliotecario.
            </p>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>