<Window x:Class="SIGEBI.Views.GestionBibliografica.AgregarRevistaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar Revista"
        Width="460" Height="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Window.Resources>
        <Style x:Key="Campo" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="Etiqueta" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2e4a36"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Background" Value="#1a5c2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0f3d20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnOutline" TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#ccc" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f5f5f5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnImagen" TargetType="Button">
            <Setter Property="Background" Value="#f4f9f6"/>
            <Setter Property="Foreground" Value="#1a5c2e"/>
            <Setter Property="BorderBrush" Value="#2e8b4a"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#e8f5e9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="Agregar Revista" FontSize="16" FontWeight="Bold"
                       Foreground="#0f3d20" Margin="0,0,0,4"/>
            <TextBlock Text="Complete los campos para registrar una nueva revista"
                       FontSize="11" Foreground="#7a9e84" Margin="0,0,0,16"/>
            <Rectangle Height="1" Fill="#dde8e2" Margin="0,0,0,4"/>

            <TextBlock Text="Imagen de portada" Style="{StaticResource Etiqueta}"/>
            <Border Width="120" Height="140" HorizontalAlignment="Left"
                    BorderBrush="#dde8e2" BorderThickness="1.5" CornerRadius="8"
                    Background="#f4f9f6" Margin="0,0,0,8">
                <Image x:Name="ImgPreview" Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
            <Button x:Name="BtnSeleccionarImagen" Content="Seleccionar imagen"
                    Style="{StaticResource BtnImagen}"
                    HorizontalAlignment="Left"
                    Click="BtnSeleccionarImagen_Click"/>
            <TextBlock x:Name="TxtRutaImagen" FontSize="10" Foreground="#7a9e84"
                       Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>

            <TextBlock Text="Titulo *" Style="{StaticResource Etiqueta}"/>
            <TextBox x:Name="TxtTitulo" Style="{StaticResource Campo}"/>

            <TextBlock Text="Autor" Style="{StaticResource Etiqueta}"/>
            <TextBox x:Name="TxtAutor" Style="{StaticResource Campo}"/>

            <TextBlock Text="Categoria *" Style="{StaticResource Etiqueta}"/>
            <ComboBox x:Name="CmbCategoria"
                      Style="{StaticResource CampoCombo}"
                      DisplayMemberPath="Nombre"
                      SelectedValuePath="Id"/>

            <TextBlock Text="Descripcion" Style="{StaticResource Etiqueta}"/>
            <TextBox x:Name="TxtDescripcion" Style="{StaticResource Campo}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10,6"/>

            <TextBlock Text="ISSN" Style="{StaticResource Etiqueta}"/>
            <TextBox x:Name="TxtISSN" Style="{StaticResource Campo}"/>

            <TextBlock Text="Numero de edicion" Style="{StaticResource Etiqueta}"/>
            <TextBox x:Name="TxtNumeroEdicion" Style="{StaticResource Campo}"/>

            <TextBlock Text="Editorial" Style="{StaticResource Etiqueta}"/>
            <TextBox x:Name="TxtEditorial" Style="{StaticResource Campo}"/>

            <TextBlock Text="Año" Style="{StaticResource Etiqueta}"/>
            <TextBox x:Name="TxtAnio" Style="{StaticResource Campo}"/>

            <TextBlock Text="Stock *" Style="{StaticResource Etiqueta}"/>
            <TextBox x:Name="TxtStock" Style="{StaticResource Campo}"/>

            <Border x:Name="ErrorPanel" Background="#fdecea" CornerRadius="7"
                    Padding="12,8" Margin="0,12,0,0" Visibility="Collapsed">
                <TextBlock x:Name="ErrorText" FontSize="11" Foreground="#c62828" TextWrapping="Wrap"/>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,28">
                <Button Content="Cancelar" Style="{StaticResource BtnOutline}"
                        Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                <Button Content="Guardar Revista" Style="{StaticResource BtnPrimario}"
                        Click="BtnGuardar_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
