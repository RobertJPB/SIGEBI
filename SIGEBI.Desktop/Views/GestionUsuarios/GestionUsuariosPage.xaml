<Page x:Class="SIGEBI.Views.GestionUsuarios.GestionUsuariosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SIGEBI.Views.GestionUsuarios"
      xmlns:conv="clr-namespace:SIGEBI.Desktop.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Gestión de Usuarios"
      Background="#f4f9f6">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ApiUrlConverter x:Key="ApiUrlConv"/>

        <Style x:Key="BtnTableAccion" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding Foreground}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Background" Value="#1a5c2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0f3d20"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16">
                            <TextBlock Text="{TemplateBinding Content}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#f0f2f0"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1a5c2e"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}"
                                BorderBrush="#1a5c2e" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER & ACTIONS -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="Cuentas de Usuario" FontSize="22" FontWeight="Bold" Foreground="#0f3d20"/>
                <TextBlock Text="{Binding Contador}" FontSize="12" Foreground="#7a9e84" Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Actualizar" Style="{StaticResource BtnSecundario}" Command="{Binding CargarUsuariosCommand}" Margin="0,0,8,0"/>
                <Button Content="+ Nuevo Usuario" Style="{StaticResource BtnPrimario}" Click="BtnNuevoUsuario_Click"/>
            </StackPanel>
        </Grid>

        <!-- SEARCH AND FILTER -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#dde8e2" BorderThickness="1" Margin="0,0,0,20" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="#7a9e84"/>
                <TextBox Grid.Column="1" Text="{Binding Busqueda, UpdateSourceTrigger=PropertyChanged}" 
                         BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" 
                         FontSize="13" Tag="Buscar por nombre o correo..."/>
            </Grid>
        </Border>

        <!-- MAIN TABLE -->
        <Grid Grid.Row="2">
            <Border Background="White" CornerRadius="10" BorderBrush="#dde8e2" BorderThickness="1">
                <DataGrid x:Name="GridUsuarios"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Usuarios}"
                          SelectedItem="{Binding SelectedUsuario}"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#f0f4f2"
                          Background="White"
                          BorderThickness="0"
                          RowHeight="54"
                          SelectionMode="Single"
                          CanUserResizeRows="False">

                    <DataGrid.Columns>
                        <!-- Perfil -->
                        <DataGridTemplateColumn Header="Usuario" Width="2.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="10,0">
                                        <Border Width="34" Height="34" CornerRadius="17" Background="#e8f5ee" ClipToBounds="True">
                                            <Grid>
                                                <TextBlock Text="👤" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#1a5c2e"/>
                                                <!-- <Image Source="{Binding ImagenUrl, Converter={StaticResource ApiUrlConv}}" Stretch="UniformToFill"/> -->
                                                <Image Source="{Binding ImagenUrl}" Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" FontSize="13" Foreground="#2c3e50"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Correo}" FontSize="11" Foreground="#7f8c8d"/>
                                                <Border x:Name="BordSancion" Background="#fff2f0" CornerRadius="4" Margin="8,0,0,0" Padding="6,1" VerticalAlignment="Center" Visibility="Collapsed">
                                                    <TextBlock Text="{Binding MotivoSancion, StringFormat='⚠ {0}'}" FontSize="9" FontWeight="Bold" Foreground="#d93025"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Estado}" Value="3">
                                            <Setter TargetName="BordSancion" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Rol -->
                        <DataGridTemplateColumn Header="Rol" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Badge}" Background="#f0f7f3">
                                        <TextBlock FontSize="10" FontWeight="Bold" Foreground="#1a5c2e">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IdRol}" Value="1"><Setter Property="Text" Value="ESTUDIANTE"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding IdRol}" Value="2"><Setter Property="Text" Value="DOCENTE"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding IdRol}" Value="3"><Setter Property="Text" Value="BIBLIOTECARIO"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding IdRol}" Value="4"><Setter Property="Text" Value="ADMIN"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Estado -->
                        <DataGridTemplateColumn Header="Estado" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="BadgeEstado" Style="{StaticResource Badge}">
                                        <TextBlock x:Name="TxtEstado" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Estado}" Value="1">
                                            <Setter TargetName="BadgeEstado" Property="Background" Value="#e6f4ea"/>
                                            <Setter TargetName="BadgeEstado" Property="ToolTip" Value="Cuenta con acceso total al sistema."/>
                                            <Setter TargetName="TxtEstado" Property="Foreground" Value="#1e8e3e"/>
                                            <Setter TargetName="TxtEstado" Property="Text" Value="ACTIVO"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Estado}" Value="2">
                                            <Setter TargetName="BadgeEstado" Property="Background" Value="#fef7e0"/>
                                            <Setter TargetName="BadgeEstado" Property="ToolTip" Value="Cuenta deshabilitada administrativamente. No es una sanción por falta."/>
                                            <Setter TargetName="TxtEstado" Property="Foreground" Value="#f9ab00"/>
                                            <Setter TargetName="TxtEstado" Property="Text" Value="INACTIVO"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Estado}" Value="3">
                                            <Setter TargetName="BadgeEstado" Property="Background" Value="#fff2f0"/>
                                            <Setter TargetName="BadgeEstado" Property="ToolTip" Value="Cuenta suspendida temporalmente por retrasos o infracciones. Recupera el acceso al vencer la sanción."/>
                                            <Setter TargetName="TxtEstado" Property="Foreground" Value="#ff4d4f"/>
                                            <Setter TargetName="TxtEstado" Property="Text" Value="SUSPENDIDO"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Estado}" Value="4">
                                            <Setter TargetName="BadgeEstado" Property="Background" Value="#fce8e6"/>
                                            <Setter TargetName="BadgeEstado" Property="ToolTip" Value="Cuenta bloqueada permanentemente por faltas graves. No recupera el acceso."/>
                                            <Setter TargetName="TxtEstado" Property="Foreground" Value="#d93025"/>
                                            <Setter TargetName="TxtEstado" Property="Text" Value="BLOQUEADO"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Acciones -->
                        <DataGridTemplateColumn Header="Acciones" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                         <!-- Activar -->
                                        <Button Content="Activar" ToolTip="Activar cuenta" Foreground="#1e8e3e"
                                                Command="{Binding DataContext.ActivarCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding Id}" Margin="2,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BtnTableAccion}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="1"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <!-- Desactivar -->
                                        <Button Content="Desactivar" ToolTip="Desactivar cuenta" Foreground="#f9ab00"
                                                Command="{Binding DataContext.DesactivarCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding Id}" Margin="2,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BtnTableAccion}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="2"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Estado}" Value="4"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Suspender -->
                                        <Button Content="Suspender" ToolTip="Suspender por sanción" Foreground="#ff4d4f"
                                                Command="{Binding DataContext.SuspenderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding Id}" Margin="2,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BtnTableAccion}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="2"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Estado}" Value="3"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Estado}" Value="4"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Bloquear -->
                                        <Button Content="Bloquear" ToolTip="Bloquear acceso" Foreground="#d93025"
                                                Command="{Binding DataContext.BloquearCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding Id}" Margin="2,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BtnTableAccion}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="4"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Rectangle Width="1" Height="20" Fill="#eee" Margin="6,0"/>

                                        <Button Content="Eliminar" ToolTip="Eliminar permanentemente" Style="{StaticResource BtnTableAccion}" Foreground="#777"
                                                Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding Id}" Margin="2,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Loading Overlay -->
            <Border Background="#88ffffff" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" CornerRadius="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#1a5c2e"/>
                    <TextBlock Text="Procesando..." Margin="0,10,0,0" Foreground="#1a5c2e" HorizontalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
