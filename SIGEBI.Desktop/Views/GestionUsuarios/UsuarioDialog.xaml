<Window x:Class="SIGEBI.Views.GestionUsuarios.UsuarioDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar Usuario"
        Width="400" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Window.Resources>
        <Style x:Key="Campo" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CampoPass" TargetType="PasswordBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="Etiqueta" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2e4a36"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Background" Value="#1a5c2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0f3d20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnOutline" TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#ccc" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f5f5f5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="28">
        <TextBlock Text="Nuevo Usuario" FontSize="16" FontWeight="Bold"
                   Foreground="#0f3d20" Margin="0,0,0,4"/>
        <TextBlock Text="Cree una cuenta para un nuevo usuario del sistema"
                   FontSize="11" Foreground="#7a9e84" Margin="0,0,0,16"/>
        <Rectangle Height="1" Fill="#dde8e2" Margin="0,0,0,10"/>

        <TextBlock Text="Nombre Completo *" Style="{StaticResource Etiqueta}"/>
        <TextBox x:Name="TxtNombre" Style="{StaticResource Campo}"/>

        <TextBlock Text="Correo Electrónico *" Style="{StaticResource Etiqueta}"/>
        <TextBox x:Name="TxtCorreo" Style="{StaticResource Campo}"/>

        <TextBlock Text="Contraseña *" Style="{StaticResource Etiqueta}"/>
        <PasswordBox x:Name="TxtPass" Style="{StaticResource CampoPass}"/>

        <TextBlock Text="Rol de Usuario *" Style="{StaticResource Etiqueta}"/>
        <ComboBox x:Name="CmbRol" Style="{StaticResource CampoCombo}">
            <ComboBoxItem Content="Estudiante" Tag="3"/>
            <ComboBoxItem Content="Bibliotecario" Tag="2"/>
            <ComboBoxItem Content="Docente" Tag="4"/>
            <ComboBoxItem Content="Administrador" Tag="1"/>
        </ComboBox>

        <Border x:Name="ErrorPanel" Background="#fdecea" CornerRadius="7"
                Padding="12,8" Margin="0,16,0,0" Visibility="Collapsed">
            <TextBlock x:Name="ErrorText" FontSize="11" Foreground="#c62828" TextWrapping="Wrap"/>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Cancelar" Style="{StaticResource BtnOutline}"
                    Margin="0,0,10,0" Click="BtnCancelar_Click"/>
            <Button Content="Registrar Usuario" Style="{StaticResource BtnPrimario}"
                    Click="BtnGuardar_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
