<Page x:Class="SIGEBI.Views.Notificaciones.NotificacionesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SIGEBI.Views.Notificaciones"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Notificaciones">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style x:Key="BtnIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16">
                            <TextBlock Text="{TemplateBinding Content}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#f0f2f0"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecundario" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1a5c2e"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#1a5c2e"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="Notificaciones del Sistema" FontSize="22" FontWeight="Bold" Foreground="#1a5c2e"/>
                <TextBlock Text="{Binding Contador}" FontSize="12" Foreground="#7a9e84" Margin="0,2,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" Content="Actualizar" Style="{StaticResource BtnSecundario}" 
                    Command="{Binding CargarNotificacionesCommand}" VerticalAlignment="Center"/>
        </Grid>

        <!-- INFO BOX -->
        <Border Grid.Row="1" Background="#eef2f8" CornerRadius="8" Margin="0,0,0,20" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x1F4E2;" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Aquí se muestran los avisos importantes sobre préstamos próximos a vencer, sanciones aplicadas y otras novedades del sistema." 
                           VerticalAlignment="Center" Foreground="#2c3e50" FontSize="13" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- MAIN TABLE -->
        <Grid Grid.Row="2">
            <Border Background="White" CornerRadius="10" BorderBrush="#dde8e2" BorderThickness="1">
                <DataGrid x:Name="GridNotificaciones"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Notificaciones}"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#f0f4f2"
                          Background="White"
                          BorderThickness="0"
                          RowHeight="60"
                          SelectionMode="Single"
                          CanUserResizeRows="False">

                    <DataGrid.Columns>
                        <!-- Fecha -->
                        <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0"/>
                                    <Setter Property="Foreground" Value="#7f8c8d"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <!-- Mensaje -->
                        <DataGridTemplateColumn Header="Mensaje" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Mensaje}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="10,4" FontSize="13"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Estado -->
                        <DataGridTemplateColumn Header="Estado" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="BadgeEstado" Style="{StaticResource Badge}">
                                        <TextBlock x:Name="TxtEstado" FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Estado}" Value="NoLeida">
                                            <Setter TargetName="BadgeEstado" Property="Background" Value="#e3f2fd"/>
                                            <Setter TargetName="TxtEstado" Property="Foreground" Value="#1565c0"/>
                                            <Setter TargetName="TxtEstado" Property="Text" Value="NUEVA"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Estado}" Value="Leida">
                                            <Setter TargetName="BadgeEstado" Property="Background" Value="#f5f5f5"/>
                                            <Setter TargetName="TxtEstado" Property="Foreground" Value="#9e9e9e"/>
                                            <Setter TargetName="TxtEstado" Property="Text" Value="LEÍDA"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Acciones -->
                        <DataGridTemplateColumn Header="Acciones" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="&#x2715;" ToolTip="Eliminar notificación" Foreground="#d93025"
                                            Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding Id}" Style="{StaticResource BtnIcon}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Loading Overlay -->
            <Border Background="#88ffffff" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" CornerRadius="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#1a5c2e"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
