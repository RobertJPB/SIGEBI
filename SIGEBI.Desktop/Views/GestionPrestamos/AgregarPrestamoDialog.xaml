<Window x:Class="SIGEBI.Views.GestionPrestamos.AgregarPrestamoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar Préstamo" Height="450" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FFFFFF" Foreground="#1A1F1C">

    <Window.Resources>
        <!-- Estilos de Inputs -->
        <Style x:Key="DialogLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2e4a36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="DialogComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1a1f1c"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#1A1F1C"/>
                        <Setter Property="Padding" Value="10,5"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogDatePicker" TargetType="DatePicker">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#1a5c2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0f3d20"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5a6b60"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f4f9f6"/>
                    <Setter Property="BorderBrush" Value="#1a5c2e"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Registrar Préstamo" FontSize="22" FontWeight="Bold" Foreground="#0f3d20" Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Usuario:" Style="{StaticResource DialogLabel}"/>
            <ComboBox x:Name="CmbUsuarios" Style="{StaticResource DialogComboBox}" DisplayMemberPath="Nombre" SelectedValuePath="Id"/>

            <TextBlock Text="Recurso a Prestar:" Style="{StaticResource DialogLabel}"/>
            <ComboBox x:Name="CmbRecursos" Style="{StaticResource DialogComboBox}" DisplayMemberPath="Titulo" SelectedValuePath="Id"/>

            <TextBlock Text="Fecha Devolución Estimada (Opcional):" Style="{StaticResource DialogLabel}"/>
            <DatePicker x:Name="DpFechaDevolucion" Style="{StaticResource DialogDatePicker}"/>
        </StackPanel>

        <!-- Botones de Acción -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar" Style="{StaticResource BtnSecondary}" Margin="0,0,12,0" Click="BtnCancelar_Click"/>
            <Button Content="Registrar" Style="{StaticResource BtnPrimary}" Click="BtnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Window>
