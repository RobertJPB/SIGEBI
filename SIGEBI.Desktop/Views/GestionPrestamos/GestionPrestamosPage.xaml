<Page x:Class="SIGEBI.Views.GestionPrestamos.GestionPrestamosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#f4f9f6">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Mismos estilos de botones -->
        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Background" Value="#1a5c2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1a5c2e"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}"
                                BorderBrush="#1a5c2e" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnTableAccion" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding Foreground}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Préstamos de Recursos" FontSize="20" FontWeight="Bold" Foreground="#0f3d20" HorizontalAlignment="Left"/>
                <TextBlock Text="Gestión, seguimiento y control de devoluciones" FontSize="12" Foreground="#7a9e84" Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="+ Registrar Préstamo" Style="{StaticResource BtnPrimario}" Click="BtnRegistrarPrestamo_Click"/>
            </StackPanel>
        </Grid>

        <!-- SEPARADOR -->
        <Rectangle Grid.Row="1" Height="1" Fill="#dde8e2" Margin="0,0,0,16"/>

        <Border Grid.Row="2" Background="#fdecea" CornerRadius="7" Padding="12,8" Margin="0,0,0,14"
                Visibility="{Binding TieneError, Converter={StaticResource BoolToVis}}">
            <TextBlock FontSize="12" Foreground="#c62828" TextWrapping="Wrap" Text="{Binding MensajeError}"/>
        </Border>

        <!-- TABLA -->
        <Border Grid.Row="3" Background="White" CornerRadius="10" BorderBrush="#dde8e2" BorderThickness="1">
            <DataGrid x:Name="GridPrestamos" AutoGenerateColumns="False" IsReadOnly="True" ItemsSource="{Binding Prestamos}"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#f0f4f2"
                      Background="White" BorderThickness="0" RowBackground="White" AlternatingRowBackground="#fafcfb"
                      FontSize="12" ColumnHeaderHeight="38" RowHeight="40" SelectionMode="Single">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#f4f9f6"/>
                        <Setter Property="Foreground" Value="#2e4a36"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="14,0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#dde8e2"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="14,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Usuario" Binding="{Binding NombreUsuario}" Width="1.5*"/>
                    <DataGridTextColumn Header="Recurso" Binding="{Binding TituloRecurso}" Width="1.5*"/>
                    <DataGridTextColumn Header="F. Inicio" Binding="{Binding FechaInicio, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="F. Límite" Binding="{Binding FechaDevolucionEstimada, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTemplateColumn Header="F. Devolución" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding FechaDevolucionReal}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FechaDevolucionReal}" Value="{x:Null}">
                                                    <Setter Property="Text" Value="En Uso"/>
                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                    <Setter Property="Foreground" Value="#5a6b60"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FechaDevolucionReal}" Value="">
                                                    <Setter Property="Text" Value="En Uso"/>
                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                    <Setter Property="Foreground" Value="#5a6b60"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <!-- Estado -->
                    <DataGridTemplateColumn Header="Estado" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="8,4" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#e8f5ee"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Estado}" Value="Activo">
                                                    <Setter Property="Background" Value="#e8f5ee"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Estado}" Value="Atrasado">
                                                    <Setter Property="Background" Value="#fdecea"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Estado}" Value="Devuelto">
                                                    <Setter Property="Background" Value="#e3f2fd"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#1a5c2e"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Estado}" Value="Activo">
                                                        <Setter Property="Foreground" Value="#1a5c2e"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Estado}" Value="Atrasado">
                                                        <Setter Property="Foreground" Value="#c62828"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Estado}" Value="Devuelto">
                                                        <Setter Property="Foreground" Value="#1565c0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Acciones -->
                    <DataGridTemplateColumn Header="Acciones" Width="260">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding DataContext.DevolverCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding Id}"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource BtnTableAccion}">
                                                <Setter Property="Content" Value="Devolver"/>
                                                <Setter Property="Foreground" Value="#2e8b4a"/>
                                                <Setter Property="BorderBrush" Value="#2e8b4a"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Estado}" Value="Devuelto">
                                                        <Setter Property="Content" Value="Devuelto"/>
                                                        <Setter Property="Background" Value="#fff176"/>
                                                        <Setter Property="Foreground" Value="#827717"/>
                                                        <Setter Property="BorderBrush" Value="#fdd835"/>
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Estado}" Value="Atrasado">
                                                        <Setter Property="Foreground" Value="#c62828"/>
                                                        <Setter Property="BorderBrush" Value="#c62828"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                         <Setter Property="Opacity" Value="1.0"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Eliminar" Style="{StaticResource BtnTableAccion}" Foreground="#c62828" Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding Id}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</Page>
