<Page x:Class="SIGEBI.Views.Penalizaciones.PenalizacionesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SIGEBI.Views.Penalizaciones"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Penalizaciones">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Background" Value="#1a5c2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0f3d20"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1a5c2e"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}"
                                BorderBrush="#1a5c2e" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16">
                            <TextBlock Text="{TemplateBinding Content}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#f0f2f0"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="Penalizaciones y Sanciones" FontSize="22" FontWeight="Bold" Foreground="#1a5c2e"/>
                <TextBlock Text="{Binding Contador}" FontSize="12" Foreground="#7a9e84" Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Actualizar" Style="{StaticResource BtnSecundario}" Command="{Binding CargarPenalizacionesCommand}" Margin="0,0,8,0"/>
                <Button Content="+ Aplicar Penalización" Style="{StaticResource BtnPrimario}" Click="BtnAplicarPenalizacion_Click"/>
            </StackPanel>
        </Grid>

        <!-- MAIN TABLE -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Border Background="White" CornerRadius="10" BorderBrush="#dde8e2" BorderThickness="1">
                <DataGrid x:Name="GridPenalizaciones"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Penalizaciones}"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#f0f4f2"
                          Background="White"
                          BorderThickness="0"
                          RowHeight="54"
                          SelectionMode="Single"
                          CanUserResizeRows="False">

                    <DataGrid.Columns>
                        <!-- Usuario -->
                        <DataGridTextColumn Header="Usuario" Binding="{Binding NombreUsuario}" Width="2*"/>
                        
                        <!-- Motivo -->
                        <DataGridTextColumn Header="Motivo / Recurso" Binding="{Binding Motivo}" Width="3*"/>

                        <!-- Monto -->
                        <DataGridTemplateColumn Header="Suspensión" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DiasSancion, StringFormat='{}{0} días'}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#d93025"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Fechas -->
                        <DataGridTextColumn Header="Desde" Binding="{Binding FechaDesde, StringFormat={}{0:dd/MM/yyyy}}" Width="*"/>

                        <!-- Estado -->
                        <DataGridTemplateColumn Header="Estado" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="BadgeEstado" Style="{StaticResource Badge}">
                                        <TextBlock x:Name="TxtEstado" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Estado}" Value="Activa">
                                            <Setter TargetName="BadgeEstado" Property="Background" Value="#fce8e6"/>
                                            <Setter TargetName="TxtEstado" Property="Foreground" Value="#d93025"/>
                                            <Setter TargetName="TxtEstado" Property="Text" Value="ACTIVA"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Estado}" Value="Finalizada">
                                            <Setter TargetName="BadgeEstado" Property="Background" Value="#e6f4ea"/>
                                            <Setter TargetName="TxtEstado" Property="Foreground" Value="#1e8e3e"/>
                                            <Setter TargetName="TxtEstado" Property="Text" Value="FINALIZADA"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Acciones -->
                        <DataGridTemplateColumn Header="Acciones" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✅" ToolTip="Finalizar y Levantar Sanción" Foreground="#1e8e3e"
                                                Command="{Binding DataContext.FinalizarCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding Id}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BtnIcon}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Finalizada">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Button Content="🗑️" ToolTip="Eliminar Penalización Permanentemente" Foreground="#d93025"
                                                Style="{StaticResource BtnIcon}"
                                                Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding Id}"
                                                Margin="4,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Loading Overlay -->
            <Border Background="#88ffffff" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" CornerRadius="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#1a5c2e"/>
                    <TextBlock Text="Procesando sanciones..." Margin="0,10,0,0" Foreground="#1a5c2e" HorizontalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
