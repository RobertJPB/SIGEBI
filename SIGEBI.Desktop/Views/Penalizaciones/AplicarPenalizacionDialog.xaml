<Window x:Class="SIGEBI.Views.Penalizaciones.AplicarPenalizacionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aplicar Penalización" Height="480" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FFFFFF" Foreground="#1A1F1C">

    <Window.Resources>
        <Style x:Key="DialogLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2e4a36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="DialogComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1a1f1c"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="DialogTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1a1f1c"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#1a5c2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5a6b60"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Aplicar Penalización" FontSize="22" FontWeight="Bold" Foreground="#0f3d20" Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Seleccionar Usuario:" Style="{StaticResource DialogLabel}"/>
            <ComboBox x:Name="CmbUsuarios" Style="{StaticResource DialogComboBox}" DisplayMemberPath="Nombre" SelectedValuePath="Id"/>

            <TextBlock Text="Motivo de la Sanción:" Style="{StaticResource DialogLabel}"/>
            <TextBox x:Name="TxtMotivo" Style="{StaticResource DialogTextBox}"/>

            <TextBlock Text="Tiempo de Suspensión (días):" Style="{StaticResource DialogLabel}"/>
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SldDias" Minimum="1" Maximum="30" Value="7" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=SldDias, StringFormat={}{0} días}" 
                           FontSize="14" FontWeight="Bold" Foreground="#1a5c2e" Margin="15,0,0,0" VerticalAlignment="Center" Width="60"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar" Style="{StaticResource BtnSecondary}" Margin="0,0,12,0" Click="BtnCancelar_Click"/>
            <Button Content="Aplicar" Style="{StaticResource BtnPrimary}" Click="BtnAplicar_Click"/>
        </StackPanel>
    </Grid>
</Window>
