<Page x:Class="SIGEBI.Views.Auditoria.AuditoriaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SIGEBI.Views.Auditoria"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Auditoría">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style x:Key="BtnSecundario" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2c3e50"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#2c3e50"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="Auditoría de Actividad" FontSize="22" FontWeight="Bold" Foreground="#2c3e50"/>
                <TextBlock Text="{Binding Contador}" FontSize="12" Foreground="#95a5a6" Margin="0,2,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" Content="Actualizar Log" Style="{StaticResource BtnSecundario}" 
                    Command="{Binding CargarAuditoriasCommand}" VerticalAlignment="Center"/>
        </Grid>

        <!-- SEARCH BAR & FILTROS -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#ecf0f1" BorderThickness="1" Margin="0,0,0,20" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="#bdc3c7"/>
                <TextBox Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                         FontSize="13" Text="{Binding FiltroUsuario, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Filtrar por usuario..."/>
                <Separator Grid.Column="2" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>
                <DatePicker Grid.Column="3" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                            FontSize="13" SelectedDate="{Binding FiltroFecha}"
                            SelectedDateFormat="Short"/>
                <Button Grid.Column="4" Content="&#x2715;" ToolTip="Limpiar filtros" BorderThickness="0"
                        Background="Transparent" Foreground="#bdc3c7" FontSize="14" Cursor="Hand" Margin="6,0,0,0"
                        Command="{Binding LimpiarFiltrosCommand}"/>
            </Grid>
        </Border>

        <!-- MAIN LOG TABLE -->
        <Grid Grid.Row="2">
            <Border Background="White" CornerRadius="10" BorderBrush="#ecf0f1" BorderThickness="1">
                <DataGrid x:Name="GridAuditoria"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Auditorias}"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#f7f9fa"
                          Background="White"
                          BorderThickness="0"
                          RowHeight="48"
                          SelectionMode="Single"
                          CanUserResizeRows="False">

                    <DataGrid.Columns>
                        <!-- Fecha -->
                        <DataGridTextColumn Header="Fecha y Hora" Binding="{Binding FechaRegistro, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0"/>
                                    <Setter Property="Foreground" Value="#7f8c8d"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Usuario -->
                        <DataGridTemplateColumn Header="Usuario" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                        <TextBlock Text="👤" Margin="0,0,8,0" Foreground="#95a5a6"/>
                                        <TextBlock Text="{Binding NombreUsuario}" FontWeight="SemiBold" Foreground="#34495e" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Operación -->
                        <DataGridTemplateColumn Header="Operación" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="BadgeOp" Style="{StaticResource Badge}">
                                        <TextBlock x:Name="TxtOp" FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding AccionDescripcion}" Value="Crear">
                                            <Setter TargetName="BadgeOp" Property="Background" Value="#e8f5ee"/>
                                            <Setter TargetName="TxtOp" Property="Foreground" Value="#2e7d32"/>
                                            <Setter TargetName="TxtOp" Property="Text" Value="CREAR"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AccionDescripcion}" Value="Actualizar">
                                            <Setter TargetName="BadgeOp" Property="Background" Value="#fff8e1"/>
                                            <Setter TargetName="TxtOp" Property="Foreground" Value="#f57f17"/>
                                            <Setter TargetName="TxtOp" Property="Text" Value="EDITAR"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AccionDescripcion}" Value="Eliminar">
                                            <Setter TargetName="BadgeOp" Property="Background" Value="#ffebee"/>
                                            <Setter TargetName="TxtOp" Property="Foreground" Value="#c62828"/>
                                            <Setter TargetName="TxtOp" Property="Text" Value="BORRAR"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AccionDescripcion}" Value="Login">
                                            <Setter TargetName="BadgeOp" Property="Background" Value="#e3f2fd"/>
                                            <Setter TargetName="TxtOp" Property="Foreground" Value="#1565c0"/>
                                            <Setter TargetName="TxtOp" Property="Text" Value="SESIÓN"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AccionDescripcion}" Value="AccesoDenegado">
                                            <Setter TargetName="BadgeOp" Property="Background" Value="#fafafa"/>
                                            <Setter TargetName="TxtOp" Property="Foreground" Value="#424242"/>
                                            <Setter TargetName="TxtOp" Property="Text" Value="BLOQUEO"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Recurso -->
                        <DataGridTextColumn Header="Entidad" Binding="{Binding TablaAfectada}" Width="1.5*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Detalle Acción -->
                        <DataGridTemplateColumn Header="Detalle Acción" Width="4*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Detalle}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="10,4" FontSize="11" Foreground="#2c3e50"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Loading Overlay -->
            <Border Background="#88ffffff" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" CornerRadius="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#34495e"/>
                    <TextBlock Text="Cargando registros de auditoría..." Margin="0,10,0,0" Foreground="#34495e" HorizontalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
