<Window x:Class="SIGEBI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGEBI - Panel Administrativo"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#f4f9f6">

    <Window.Resources>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Brd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="8,2">
                            <ContentPresenter Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Brd" Property="Background" Value="#1a5c2e"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Brd" Property="Background" Value="#0f3d20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="#1a5c2e"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── SIDEBAR ── -->
        <Border Grid.Column="0" Background="#0d2e18">
            <DockPanel>

                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,16">
                    <TextBlock Text="SIGEBI"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Panel Administrativo"
                               FontSize="10" Foreground="#4caf7d"
                               FontWeight="SemiBold"/>
                    <Rectangle Height="1" Fill="#1a5c2e" Margin="0,14,0,0"/>
                </StackPanel>

                <!-- Cerrar sesión al fondo -->
                <Button DockPanel.Dock="Bottom"
                        Style="{StaticResource NavBtn}"
                        Margin="0,0,0,16"
                        Click="BtnCerrarSesion_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="4" Height="16" Background="#ff8a80" CornerRadius="2" Margin="0,0,10,0"/>
                        <TextBlock Text="Cerrar Sesión"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#ff8a80" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Nav Items -->
                <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">

                    <Button x:Name="BtnBibliografica"
                            Style="{StaticResource NavBtnActive}"
                            Click="BtnBibliografica_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" Height="16" Background="#4caf7d" CornerRadius="2" Margin="0,0,10,0"/>
                            <TextBlock Text="Gestión Bibliográfica"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPrestamos"
                            Style="{StaticResource NavBtn}"
                            Click="BtnPrestamos_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" Height="16" Background="#4caf7d" CornerRadius="2" Margin="0,0,10,0"/>
                            <TextBlock Text="Préstamos"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#a0c4ac" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnUsuarios"
                            Style="{StaticResource NavBtn}"
                            Click="BtnUsuarios_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" Height="16" Background="#4caf7d" CornerRadius="2" Margin="0,0,10,0"/>
                            <TextBlock Text="Usuarios"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#a0c4ac" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPenalizaciones"
                            Style="{StaticResource NavBtn}"
                            Click="BtnPenalizaciones_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" Height="16" Background="#4caf7d" CornerRadius="2" Margin="0,0,10,0"/>
                            <TextBlock Text="Penalizaciones"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#a0c4ac" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnNotificaciones"
                            Style="{StaticResource NavBtn}"
                            Click="BtnNotificaciones_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" Height="16" Background="#4caf7d" CornerRadius="2" Margin="0,0,10,0"/>
                            <TextBlock Text="Notificaciones"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#a0c4ac" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnAuditoria"
                            Style="{StaticResource NavBtn}"
                            Click="BtnAuditoria_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" Height="16" Background="#4caf7d" CornerRadius="2" Margin="0,0,10,0"/>
                            <TextBlock Text="Auditoría"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#a0c4ac" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ── CONTENT AREA ── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="#dde8e2" BorderThickness="0,0,0,1">
                <DockPanel Margin="24,0">
                    <TextBlock x:Name="TxtSeccionActual"
                               Text="Gestión Bibliográfica"
                               FontSize="15" FontWeight="Bold"
                               Foreground="#0f3d20"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Frame para cargar vistas -->
            <Frame x:Name="MainFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="#f4f9f6"/>
        </Grid>

    </Grid>
</Window>
