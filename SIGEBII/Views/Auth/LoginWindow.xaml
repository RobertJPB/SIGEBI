<Window x:Class="SIGEBI.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGEBI - Acceso Administrativo"
        Height="620" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0d2e18">

    <Window.Resources>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#fafcfb"/>
            <Setter Property="Foreground" Value="#1a1f1c"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#fafcfb"/>
            <Setter Property="Foreground" Value="#1a1f1c"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnLogin" TargetType="Button">
            <Setter Property="Background" Value="#1a5c2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0f3d20"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#071f10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0d2e18" Offset="0"/>
                <GradientStop Color="#1a5c2e" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Background="White"
                CornerRadius="16"
                Width="420"
                Padding="40,36"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.3" BlurRadius="30" ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel>

                <!-- Brand -->
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="SIGEBI"
                               FontSize="26" FontWeight="Bold"
                               Foreground="#0f3d20"/>
                    <TextBlock Text="B I B L I O T E C A"
                               FontSize="10" Foreground="#8a9e90"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Acceso Administrativo -->
                <Border Background="#fdecea" CornerRadius="6"
                        Padding="10,6" Margin="0,4,0,20"
                        HorizontalAlignment="Left">
                    <TextBlock Text="A C C E S O   A D M I N I S T R A T I V O"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#c62828"/>
                </Border>

                <!-- Título -->
                <TextBlock Text="Bienvenido"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#0f3d20"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Ingresa tus credenciales para continuar"
                           FontSize="13" Foreground="#8a9e90"
                           Margin="0,0,0,24"/>

                <!-- Error -->
                <Border x:Name="ErrorPanel"
                        Background="#fdecea" CornerRadius="7"
                        Padding="12,10" Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText"
                               FontSize="12" Foreground="#c62828"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Correo -->
                <TextBlock Text="Correo electrónico"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#2e4a36" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtCorreo"
                         Style="{StaticResource InputStyle}"
                         Margin="0,0,0,16"/>

                <!-- Contraseña -->
                <TextBlock Text="Contraseña"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#2e4a36" Margin="0,0,0,6"/>
                <PasswordBox x:Name="TxtContrasena"
                             Style="{StaticResource PasswordStyle}"
                             Margin="0,0,0,24"/>

                <!-- Botón -->
                <Button Content="Iniciar Sesión"
                        Style="{StaticResource BtnLogin}"
                        Click="BtnLogin_Click"/>

                <!-- Footer -->
                <TextBlock Text="¿Problemas para acceder? Contacta al administrador."
                           FontSize="11" Foreground="#aabdb2"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,18,0,0"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
