<Page x:Class="SIGEBI.Views.GestionBibliografica.GestionBibliograficaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#f4f9f6">

    <Page.Resources>

        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Background" Value="#1a5c2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0f3d20"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#071f10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1a5c2e"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#1a5c2e"
                                BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#e8f5ee"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnEditar" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1565c0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#1565c0"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#e3f2fd"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#c62828"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#c62828"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#fdecea"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#dde8e2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Recursos Bibliográficos"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#0f3d20"
                           HorizontalAlignment="Left"/>
                <TextBlock Text="Gestión de libros, revistas y documentos"
                           FontSize="12" Foreground="#7a9e84"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="+ Agregar Libro"
                        Style="{StaticResource BtnPrimario}"
                        Margin="0,0,8,0"
                        Click="BtnAgregarLibro_Click"/>
                <Button Content="+ Agregar Revista"
                        Style="{StaticResource BtnSecundario}"
                        Margin="0,0,8,0"
                        Click="BtnAgregarRevista_Click"/>
                <Button Content="+ Agregar Documento"
                        Style="{StaticResource BtnSecundario}"
                        Click="BtnAgregarDocumento_Click"/>
            </StackPanel>
        </Grid>

        <!-- ── SEPARADOR ── -->
        <Rectangle Grid.Row="1" Height="1" Fill="#dde8e2" Margin="0,0,0,16"/>

        <!-- ── BARRA DE BÚSQUEDA ── -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtBusqueda"
                     Grid.Column="0"
                     Style="{StaticResource SearchBox}"
                     KeyDown="TxtBusqueda_KeyDown"/>

            <Button Grid.Column="1" Content="Buscar"
                    Style="{StaticResource BtnPrimario}"
                    Margin="8,0,0,0"
                    Click="BtnBuscar_Click"/>

            <Button Grid.Column="2" Content="Limpiar"
                    Style="{StaticResource BtnSecundario}"
                    Margin="8,0,0,0"
                    Click="BtnVerTodos_Click"/>

            <TextBlock x:Name="TxtContador"
                       Grid.Column="4"
                       FontSize="12" Foreground="#7a9e84"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- ── MENSAJE ── -->
        <Border x:Name="MensajePanel" Grid.Row="2"
                Background="#fdecea" CornerRadius="7"
                Padding="12,8" Margin="0,46,0,0"
                Visibility="Collapsed" VerticalAlignment="Top">
            <TextBlock x:Name="MensajeText"
                       FontSize="12" Foreground="#c62828"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ── TABLA ── -->
        <Border Grid.Row="3"
                Background="White"
                CornerRadius="10"
                BorderBrush="#dde8e2"
                BorderThickness="1">
            <DataGrid x:Name="GridRecursos"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#f0f4f2"
                      Background="White"
                      BorderThickness="0"
                      RowBackground="White"
                      AlternatingRowBackground="#fafcfb"
                      FontSize="12"
                      ColumnHeaderHeight="38"
                      RowHeight="40"
                      SelectionMode="Single"
                      CanUserResizeRows="False"
                      CanUserReorderColumns="False">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#f4f9f6"/>
                        <Setter Property="Foreground" Value="#2e4a36"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="14,0"/>
                        <Setter Property="BorderBrush" Value="#dde8e2"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="14,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#e8f5ee"/>
                                <Setter Property="Foreground" Value="#0f3d20"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f4faf7"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Título"    Binding="{Binding Titulo}"         Width="2*"/>
                    <DataGridTextColumn Header="Autor"     Binding="{Binding Autor}"           Width="*"/>
                    <DataGridTextColumn Header="Tipo"      Binding="{Binding TipoRecurso}"     Width="90"/>
                    <DataGridTextColumn Header="Categoría" Binding="{Binding CategoriaNombre}" Width="120"/>
                    <DataGridTextColumn Header="Stock"     Binding="{Binding Stock}"           Width="60"/>
                    <DataGridTextColumn Header="Estado"    Binding="{Binding Estado}"          Width="100"/>
                    <DataGridTemplateColumn Header="" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Editar"
                                            Style="{StaticResource BtnEditar}"
                                            Tag="{Binding}"
                                            Margin="0,0,6,0"
                                            Click="BtnEditar_Click"/>
                                    <Button Content="Eliminar"
                                            Style="{StaticResource BtnDanger}"
                                            Tag="{Binding Id}"
                                            Click="BtnEliminar_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</Page>
